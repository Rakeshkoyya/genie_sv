# ─────────────────────────────────────────────
#  genie_sv — backend environment variables
#  Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── Database (Supabase Postgres) ──────────────
# Supports both postgresql:// and postgresql+asyncpg:// — auto-converted at startup
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.xxxx.supabase.co:5432/postgres

# ── Supabase (storage + auth) ─────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenRouter LLM ────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
# Default model — override if needed
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # optional, this is the default

# ── Auth — must match frontend AUTH_SECRET ────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# ── Server ────────────────────────────────────
DEBUG=false
# JSON array of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]

# ── Storage bucket names (optional — defaults shown) ──
# INPUT_FILES_BUCKET=input-files
# EXPORTS_BUCKET=exports
